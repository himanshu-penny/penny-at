# ─────────────────────────────────────────────────────────────────────────────
# PLAYWRIGHT FUSION FRAMEWORK — Environment Configuration
#
# This framework uses CLIENT-mode exclusively. URLs come from the built-in
# URL map in src/config/client-config.ts. Credentials come from per-client
# env files at src/config/clients/{client}/{env}.env (gitignored).
#
# Usage:
#   CLIENT=ewcf  TEST_ENV=test   npx playwright test
#   CLIENT=rcmc  TEST_ENV=fb     npx playwright test
#   CLIENT=srmg  TEST_ENV=prod   npx playwright test
#
# Valid CLIENT values   : ewcf | rcmc | srmg | voltalia | enterprise | sabil
# Valid TEST_ENV values : dev | test | fb | demo | prod | sabil.tst
#
# Credential files:
#   Copy src/config/clients/{client}/{env}.env.example
#   to   src/config/clients/{client}/{env}.env
#   and fill in USER_EMAIL, USER_PASSWORD, ADMIN_EMAIL, ADMIN_PASSWORD.
#
# Never commit .env files — only .env.example files are committed.
# ─────────────────────────────────────────────────────────────────────────────

CLIENT=ewcf
TEST_ENV=test

# ─────────────────────────────────────────────────────────────────────────────
# SABIL INBOUND INTEGRATION (only needed when CLIENT=sabil)
#
# Example:
#   CLIENT=sabil
#   TEST_ENV=sabil.tst
# ─────────────────────────────────────────────────────────────────────────────

# Sabil tenant org code — sent as the X-ORG-CODE header on inbound integration calls
SABIL_ORG_CODE=orgXXXXXXXXX

# Base URL for inbound integration calls. The /api path prefix is applied to every
# /integrations/sabil/* endpoint (health, pr, vendor/sync, po/sync, grn, bill/sync, ...).
SABIL_PENNY_BASE_URL=https://api-sabil.tst.penny.co/api

# Existing Penny vendor id in the tenant org — vendor/sync callbacks resolve against it
SABIL_VENDOR_PENNY_ID=orgXXXXXXXXX-ven-XXXX

# Plane API — used by create-qa-tasks.mjs
# Profile → API tokens → Add token
PLANE_API_TOKEN=plane_api_your_token_here
