{
  "name": "penny-at",
  "version": "1.0.0",
  "description": "A production-grade Playwright automation framework for Penny Web UI and REST API testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --project=api-testing",
    "test:api:allure": "ALLURE_RUNTIME_METADATA=true playwright test --project=api-testing",
    "test:api:manual": "MANUAL_TEST_REPORT=true ALLURE_RUNTIME_METADATA=true playwright test --project=api-testing --workers=1",
    "test:api:shared": "playwright test src/tests/shared/api --project=api-testing",
    "test:api:sabil": "playwright test src/tests/shared/api src/tests/sabil/api --project=api-testing",
    "test:web": "playwright test --project=smoke",
    "test:web:allure": "ALLURE_RUNTIME_METADATA=true playwright test --project=smoke",
    "test:web:ewcf": "playwright test src/tests/shared/web src/tests/ewcf/web --project=smoke",
    "test:web:sabil": "playwright test src/tests/shared/web src/tests/sabil/web --project=smoke",
    "test:parallel": "playwright test --workers=4",
    "test:ci": "CI=true playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report artifacts/reports/html",
    "report:allure": "node scripts/strip-ansi-allure.js && allure generate artifacts/reports/allure-results --clean -o artifacts/reports/allure-html && allure open artifacts/reports/allure-html",
    "report:allure:generate": "node scripts/strip-ansi-allure.js && allure generate artifacts/reports/allure-results --clean -o artifacts/reports/allure-html",
    "report:allure:open": "allure open artifacts/reports/allure-html",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:api:list",
    "test:api:list": "playwright test --project=api-testing --list",
    "setup": "bash scripts/setup.sh",
    "cleanup": "bash scripts/cleanup.sh",
    "generate:schema": "node scripts/generate-schema.js",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "api-testing",
    "penny"
  ],
  "author": "QA Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "eslint": "^9.16.0",
    "genson-js": "^0.0.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.4.7"
  }
}
